# ── AI 顾问配置 ────────────────────────────────────────────
# 可选：配置后启用 GPT 推荐，不配置则使用规则引擎 fallback
OPENAI_API_KEY=sk-your-key-here

# ── 服务端口 ───────────────────────────────────────────────
PORT=3001

# ── JWT 认证密钥（生产环境必须替换为强随机字符串）──────────
JWT_SECRET=dev-secret-change-in-production

# ── 运行环境 ───────────────────────────────────────────────
# development：自动绕过 admin 路由认证（方便本地开发）
# production：强制要求 JWT 认证
NODE_ENV=development
